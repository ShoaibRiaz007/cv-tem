generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model documents {
  id         BigInt                       @id @default(autoincrement())
  text       String
  metadata   Json?                        @default("{}")
  embedding  Unsupported("vector(3072)")?
  created_at DateTime?                    @default(now()) @db.Timestamptz(6)
  updated_at DateTime?                    @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_documents_created_at")
  @@index([metadata], map: "idx_documents_metadata", type: Gin)
}

model projects {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  title            String
  tagline          String
  industry         String?
  projectType      String?
  status           String?
  role             String
  engagementModel  String?
  teamSize         Int?
  durationInMonths Int?
  problem          String   @db.Text
  context          String?  @db.Text
  strategy         String   @db.Text
  architecture     String   @db.Text
  execution        String   @db.Text
  challenges       String?  @db.Text
  solution         String   @db.Text
  measurableImpact String   @db.Text
  metrics          Json?
  techStack        String[]
  infrastructure   String[]
  integrations     String[]
  coverImage       String
  galleryImages    String[]
  demoUrl          String?
  repositoryUrl    String?
  seoTitle         String?
  seoDescription   String?
  keywords         String[]
  featured         Boolean  @default(false)
  published        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model testimonials {
  image       String?
  id          Int     @id @default(autoincrement())
  company     String
  content     String
  designation String
  client_name String
}
